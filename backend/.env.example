# ─────────────────────────────────────────────────────────────────
# Arch-Enemy — Backend Environment Variables
# Copy this file to backend/.env and fill in your real values.
# NEVER commit .env to git. service-account.json is also gitignored.
# ─────────────────────────────────────────────────────────────────

# ── GCP Vision ────────────────────────────────────────────────────
# Path to your GCP service account JSON key file.
# The file is at the project root: ../service-account.json
# How to get it:
#   1. Go to console.cloud.google.com → select/create project "arch-enemy"
#   2. Enable "Cloud Vision API" (APIs & Services → Library)
#   3. IAM & Admin → Service Accounts → Create Service Account
#   4. Grant role: "Cloud Vision API User"
#   5. Keys tab → Add Key → JSON → Download → rename to service-account.json
#   6. Place the file in the project root (Bearhacks26/)
GOOGLE_APPLICATION_CREDENTIALS=../service-account.json

# ── Snowflake ─────────────────────────────────────────────────────
# How to get:
#   1. Log in to app.snowflake.com
#   2. Account identifier: shown in Admin → Accounts (format: orgname-accountname)
#      OR the URL subdomain: https://<ACCOUNT>.snowflakecomputing.com
#   3. Create a warehouse, database, schema, and role via Snowflake worksheet:
#      CREATE WAREHOUSE ARCH_ENEMY_WH WITH WAREHOUSE_SIZE='X-SMALL' AUTO_SUSPEND=60;
#      CREATE DATABASE ARCH_ENEMY_DB;
#      CREATE SCHEMA ARCH_ENEMY_DB.PUBLIC;
#      CREATE ROLE ARCH_ENEMY_ROLE;
#      GRANT USAGE ON WAREHOUSE ARCH_ENEMY_WH TO ROLE ARCH_ENEMY_ROLE;
#      GRANT ALL ON DATABASE ARCH_ENEMY_DB TO ROLE ARCH_ENEMY_ROLE;
#      GRANT ROLE ARCH_ENEMY_ROLE TO USER <your_user>;
SNOWFLAKE_ACCOUNT=GC38237
SNOWFLAKE_DATABASE=ARCH_ENEMY_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=ARCH_ENEMY_WH
SNOWFLAKE_ROLE=ARCH_ENEMY_ROLE
SNOWFLAKE_USER=ARCH_ENEMY_USER
SNOWFLAKE_PASSWORD='testinguser123'

# ── ElevenLabs — TTS Streaming ────────────────────────────────────
# How to get:
#   1. Sign up at elevenlabs.io
#   2. Profile → API Keys → Create new key → copy it here
#   3. Go to Voices → choose a voice → copy the Voice ID from the URL
#      or from the voice settings panel
ELEVENLABS_API_KEY=sk_e175c261b4deafb702112feabe1aed1619038fae0553d51e
ELEVENLABS_VOICE_ID=1SM7GgM6IMuvQlz2BwM3

# ── ElevenLabs — Conversational AI Agent ─────────────────────────
# How to get:
#   1. elevenlabs.io → Products → Conversational AI → Create Agent
#   2. Set the system prompt to the Arch-Enemy persona (sarcastic Principal Engineer)
#   3. Add a client tool called "architecture_query" with these params:
#        - question (string): the user's architecture question
#        - diagram_mermaid (string): current diagram context
#      Set the webhook URL to: http://localhost:8000/ws/webhook/architecture-query
#   4. Copy the Agent ID from the agent settings page
ELEVENLABS_AGENT_ID=your_agent_id

# ── App Config ────────────────────────────────────────────────────
# Frontend origin allowed by CORS (change if deploying)
CORS_ORIGIN=http://localhost:5173
# Backend base URL (used by watcher.py if running in desktop mode)
BACKEND_URL=http://localhost:8000
